# ─── Netlify Functions ───────────────────────────────────────────────────────
# Bridge Interactive API (MLS data)
BRIDGE_API_TOKEN=your_bridge_api_token_here
BRIDGE_DATASET_ID=miamire
BRIDGE_BASE_URL=https://api.bridgedataoutput.com/api/v2/OData/

# Gemini AI (Miami Desk AI)
Gemini_API_Key=your_gemini_api_key_here

# Resend (lead acknowledgment emails)
RESEND_API_KEY=your_resend_api_key_here
RESEND_FROM=Carlos Uzcategui <no-reply@homesprofessional.com>

# Google Sheets webhook (optional — for CRM integration)
GOOGLE_SHEETS_WEBHOOK_URL=https://hooks.example.com/your-webhook

# Market feed security
MARKET_FEED_REFRESH_SECRET=your_random_secret_here

# ─── Analytics (client-side, no secrets) ────────────────────────────────────
# These are NOT secrets — they go in index.html or loaded via GTM.
# VITE_GA4_MEASUREMENT_ID=G-XXXXXXXXXX
# VITE_META_PIXEL_ID=XXXXXXXXXXXXXXXXXX

# ─── Deployment ──────────────────────────────────────────────────────────────
# Production domain (used for canonical URLs, OG tags, sitemaps)
# VITE_SITE_URL=https://homesprofessional.com
