# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# VITE_GOOGLE_MAPS_KEY: Powers the address autocomplete + map-pin preview on the
# seller forms. Without it the Property Address field has no suggestions and no
# map preview. Must be VITE_-prefixed (exposed to the browser at build time).
# Requires Maps JavaScript API + Places API enabled AND billing on in Google Cloud.
# See ENVIRONMENT_VARIABLES.md for the full setup steps.
VITE_GOOGLE_MAPS_KEY="MY_GOOGLE_MAPS_BROWSER_KEY"

# ──────────────────────────────────────────────────────────────────────────
# Lead notifications (server-side only — set real values in Netlify env vars)
# ──────────────────────────────────────────────────────────────────────────

# CALLMEBOT_APIKEY: Instant WhatsApp alert to Carlos on every lead.
# Used by netlify/functions/{submission-created,lead-notify}.ts via _shared/whatsapp.ts.
# Activate once from the RECIPIENT's WhatsApp (message "I allow callmebot to send
# me messages" to +34 644 51 95 23); the bot replies with the key. The key is
# bound to that phone number. See ENVIRONMENT_VARIABLES.md.
CALLMEBOT_APIKEY="MY_CALLMEBOT_APIKEY"

# CALLMEBOT_PHONE: Number that receives the alerts. Optional; defaults to
# +19548656622. Must include the country code with a leading "+" and match the
# number that activated CALLMEBOT_APIKEY.
CALLMEBOT_PHONE="+19548656622"

# ──────────────────────────────────────────────────────────────────────────
# Live MLS listings (Bridge Data Output / Bridge Interactive IDX)
# SERVER-SIDE ONLY — read inside netlify/functions/*, never exposed to the
# browser. Do NOT prefix with VITE_. Put the real value in Netlify env vars
# (and, for local dev, in a .env file — which .gitignore already excludes).
# ──────────────────────────────────────────────────────────────────────────

# BRIDGE_API_TOKEN: The Bridge SERVER token (not the browser/public token).
# 32 hex characters, no spaces/quotes/line breaks.
# Used by: listings-search, bridge-listings, ticker-listings, city-stats,
#          refresh-market-feed, _shared/bridgeMlsForAi
# Get it: bridgedataoutput.com → Login → API Access → Server Token
BRIDGE_API_TOKEN="MY_BRIDGE_SERVER_TOKEN"

# BRIDGE_DATASET_ID: Your MLS dataset slug in the Bridge API URL.
# Default "miamire" (Miami Realtors Exchange). If wrong, the API returns 403.
BRIDGE_DATASET_ID="miamire"
