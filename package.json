{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "postbuild": "react-snap",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "include": [
      "/",
      "/sell",
      "/buy",
      "/agents",
      "/spain-desk",
      "/contact",
      "/listings",
      "/about",
      "/market/weston",
      "/market/pembroke-pines",
      "/market/plantation",
      "/market/miramar",
      "/market/miami",
      "/market/coral-gables",
      "/market/doral",
      "/market/kendall",
      "/market/fort-lauderdale",
      "/market/hollywood",
      "/market/aventura",
      "/market/miami-beach",
      "/market/homestead",
      "/market/boca-raton",
      "/market/coral-springs",
      "/market/parkland",
      "/market/miami-lakes",
      "/market/hallandale",
      "/market/pompano-beach",
      "/market/sunrise",
      "/market/brickell"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.1",
    "react-dom": "^19.0.1",
    "react-helmet-async": "^3.0.0",
    "react-router-dom": "^7.15.1",
    "vite": "^6.2.3"
  },
  "devDependencies": {
    "@netlify/functions": "^5.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "react-snap": "^1.23.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3",
    "vite-plugin-sitemap": "^0.8.2"
  }
}
