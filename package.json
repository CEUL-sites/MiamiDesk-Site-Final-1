{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "build": "vite build",
    "postbuild": "react-snap",
    "preview": "vite preview",
    "clean": "rm -rf dist",
    "lint": "tsc --noEmit"
  },
  "reactSnap": {
    "source": "dist",
    "destination": "dist",
    "puppeteerArgs": [
      "--no-sandbox",
      "--disable-setuid-sandbox"
    ],
    "include": [
      "/",
      "/sell",
      "/buy",
      "/new-construction",
      "/markets",
      "/agents",
      "/spain-desk",
      "/madrid",
      "/contact",
      "/listings",
      "/about",
      "/press",
      "/privacy",
      "/terms",
      "/es",
      "/es/vender",
      "/es/comprar",
      "/es/agentes",
      "/es/gracias/agente",
      "/es/spain-desk",
      "/es/madrid",
      "/journal",
      "/journal/miami-luxury-market-q3-2026",
      "/journal/selling-coral-gables-2026",
      "/thanks/seller",
      "/thanks/buyer",
      "/thanks/agent"
    ]
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.3.0",
    "@vitejs/plugin-react": "^5.2.0",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "i18next": "^26.2.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.38.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-helmet-async": "^3.0.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1",
    "tailwindcss": "^4.3.0",
    "vite": "^6.4.2"
  },
  "devDependencies": {
    "@netlify/blobs": "^10.0.0",
    "@netlify/functions": "^5.2.2",
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.5.0",
    "react-snap": "^1.23.0",
    "tailwindcss": "^4.3.0",
    "tsx": "^4.22.0",
    "typescript": "~5.8.3",
    "vite": "^6.4.2",
    "vite-plugin-sitemap": "^0.8.2"
  }
}
