# ===========================================================================
# CarlosRE Social Automation — environment variables
# Copy this file to .env and fill in your keys.  .env is gitignored.
# Run with:  node --env-file=.env src/run.js
# ===========================================================================

# --- REQUIRED for a dry run (preview copy only) ----------------------------

# Anthropic Claude API key  ->  https://console.anthropic.com/keys
ANTHROPIC_API_KEY=

# Google AI Studio key (Gemini "Nano Banana")  ->  https://aistudio.google.com/app/apikey
GEMINI_API_KEY=

# --- REQUIRED for a full live run ------------------------------------------

# Google Drive OAuth2 — desktop/web client downloaded from
# https://console.cloud.google.com/apis/credentials  (Drive API must be enabled)
# Point this at the JSON file you saved in credentials/ .
GOOGLE_OAUTH_CREDENTIALS=credentials/google_oauth_client.json
# Where the saved OAuth token is cached after the one-time consent flow.
GOOGLE_TOKEN_PATH=credentials/google_token.json
# Filled in automatically after the first run so the folder is reused.
DRIVE_ROOT_FOLDER_ID=

# Canva API  ->  https://www.canva.com/developers
CANVA_API_TOKEN=
# Optional: a Canva Brand Template ID to compose against (if you have one).
CANVA_BRAND_TEMPLATE_ID=

# Buffer API  ->  https://buffer.com/developers
BUFFER_ACCESS_TOKEN=
# Profile (channel) IDs — list them with the curl command in the README.
BUFFER_PROFILE_ID_INSTAGRAM=
BUFFER_PROFILE_ID_LINKEDIN=
BUFFER_PROFILE_ID_FACEBOOK=

# --- OPTIONAL --------------------------------------------------------------

# Bridge Interactive MLS API  ->  https://www.bridgeinteractive.com/developers
# Leave blank to skip MLS sourcing entirely.
BRIDGE_API_KEY=
BRIDGE_API_BASE=https://api.bridgedataoutput.com/api/v2

# Timezone used for scheduling windows (Buffer slots are defined in ET).
SCHEDULE_TIMEZONE=America/New_York
